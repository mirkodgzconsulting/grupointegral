---
import Button from './ui/Button.astro';
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-white overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-bg-accent opacity-50 blur-3xl"></div>
    <div class="absolute bottom-0 -left-20 w-96 h-96 rounded-full bg-[#EEF2FF] opacity-30 blur-2xl"></div>
  </div>

  <div class="container-gi relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Copy -->
      <div>
        <!-- Location badge -->
        <div class="inline-flex items-center gap-1.5 bg-bg-accent border border-accent/20 text-accent text-xs font-heading font-semibold uppercase tracking-wider px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
          Lombardía · Milán · Online
        </div>

        <h1 class="font-heading font-bold text-primary leading-tight mb-5" style="font-size:clamp(32px,5vw,48px);line-height:1.1">
          Construye tu futuro en Italia con el respaldo que mereces
        </h1>

        <p class="text-text-body text-lg leading-relaxed mb-8 max-w-lg">
          En Grupo Integral reunimos los mejores servicios para que la comunidad latina en Italia pueda estudiar, regularizarse, trabajar y emprender — sin perderse en trámites ni burocracia, y siempre con atención en español.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-6">
          <Button href="/#contacto" variant="primary" size="lg">
            Quiero información gratuita
          </Button>
          <Button href="https://wa.me/393513427777" variant="whatsapp" size="lg" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Hablar por WhatsApp
          </Button>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-body mb-5">
          <span class="flex items-center gap-1.5"><span class="text-success font-bold">✓</span> Sin compromiso</span>
          <span class="text-border">·</span>
          <span class="flex items-center gap-1.5"><span class="text-success font-bold">✓</span> Respuesta en menos de 24h</span>
          <span class="text-border">·</span>
          <span class="flex items-center gap-1.5"><span class="text-success font-bold">✓</span> Atención en español</span>
        </div>

        <!-- Social proof -->
        <p class="text-sm text-text-body/80 flex items-center gap-2">
          <span class="flex -space-x-2">
            <span class="w-7 h-7 rounded-full bg-accent/20 border-2 border-white flex items-center justify-center text-xs font-semibold text-accent">M</span>
            <span class="w-7 h-7 rounded-full bg-success/20 border-2 border-white flex items-center justify-center text-xs font-semibold text-success">C</span>
            <span class="w-7 h-7 rounded-full bg-primary/10 border-2 border-white flex items-center justify-center text-xs font-semibold text-primary">L</span>
          </span>
          Más de <strong class="text-primary">500 personas</strong>&nbsp;de la comunidad latina ya confían en nosotros
        </p>
      </div>

      <!-- Right: Visual placeholder -->
      <div class="relative hidden lg:block">
        <div class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-bg-accent to-[#dde4ff] aspect-[4/3] flex items-center justify-center shadow-xl">
          <div class="text-center p-8">
            <div class="w-24 h-24 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>
              </svg>
            </div>
            <p class="text-primary/60 font-heading font-semibold text-sm">Imagen del equipo / Milano</p>
            <p class="text-primary/40 text-xs mt-1">Reemplazar con foto real</p>
          </div>

          <!-- Floating stats card -->
          <div class="absolute bottom-6 left-6 bg-white rounded-xl p-4 shadow-lg border border-border">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-success/10 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-primary text-sm">+500 clientes</p>
                <p class="text-text-body text-xs">en toda Italia</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
