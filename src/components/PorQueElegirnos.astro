---
import Badge from './ui/Badge.astro';

const items = [
  {
    title: 'Atención en español e italiano',
    desc: 'Comunicamos en tu idioma. Sin malentendidos, sin traducciones a medias.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802"/>`,
  },
  {
    title: 'Acompañamiento personalizado',
    desc: 'No eres un número. Cada caso es distinto y lo tratamos como tal.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
  },
  {
    title: 'Red de aliados acreditados',
    desc: 'Trabajamos solo con entidades reconocidas y programas oficiales en Italia.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
  },
  {
    title: 'Formación certificada',
    desc: 'Los cursos que ofrecemos son válidos ante instituciones italianas y europeas.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>`,
  },
  {
    title: 'Todo en un solo lugar',
    desc: 'Migración, fiscalidad, formación y emprendimiento — sin ir de ventanilla en ventanilla.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`,
  },
  {
    title: 'Presencia física en Lombardía',
    desc: 'Puedes venir a vernos. Tenemos oficina en Milán y atendemos también online.',
    svg: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>`,
  },
];
---

<section class="section-padding bg-white">
  <div class="container-gi">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <Badge class="mb-4">Por qué elegirnos</Badge>
      <h2 class="font-heading font-bold text-primary text-h2">
        Tu proceso en Italia, con respaldo profesional
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item) => (
        <div class="group p-6 rounded-card border border-border hover:border-accent/40 hover:shadow-card transition-all duration-200 bg-white">
          <div class="w-11 h-11 rounded-xl bg-bg-accent group-hover:bg-accent/15 flex items-center justify-center mb-4 transition-colors duration-200">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={item.svg} />
          </div>
          <h3 class="font-heading font-semibold text-primary text-base mb-2">{item.title}</h3>
          <p class="text-text-body text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
