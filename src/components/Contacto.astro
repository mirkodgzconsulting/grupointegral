---
import Badge from './ui/Badge.astro';

const services = [
  'MasterCAF — Formación fiscal',
  'Programa GOL — Formación gratuita',
  'Test de italiano A2/B1',
  'Consultoría migratoria',
  'Partita IVA / Servicios fiscales',
  'Asesoría para emprender',
  'Business Plan',
  'Orientación laboral',
  'Otro',
];
---

<section class="section-padding bg-white" id="contacto">
  <div class="container-gi">
    <div class="text-center max-w-xl mx-auto mb-14">
      <Badge class="mb-4">Contacto</Badge>
      <h2 class="font-heading font-bold text-primary text-h2 mb-3">
        Estamos para ayudarte
      </h2>
      <p class="text-text-body leading-relaxed">
        Cuéntanos tu situación y un asesor te responderá en menos de 24 horas.
        La consulta inicial es completamente gratuita.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 items-start">

      <!-- Form (col-span 3) -->
      <div class="lg:col-span-3">
        <!-- GoHighLevel placeholder — reemplazar con embed GHL -->
        <div id="ghl-form-placeholder" class="bg-bg-section rounded-2xl border border-border p-8">
          <p class="text-xs font-heading font-semibold uppercase tracking-wider text-accent mb-6">Consulta gratuita y sin compromiso</p>

          <form class="space-y-4" onsubmit="return false;">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="nombre">Nombre completo *</label>
                <input id="nombre" type="text" required placeholder="Tu nombre"
                  class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary placeholder:text-text-body/40 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition" />
              </div>
              <div>
                <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="telefono">Teléfono *</label>
                <input id="telefono" type="tel" required placeholder="+39 o tu prefijo"
                  class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary placeholder:text-text-body/40 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="email">Email *</label>
                <input id="email" type="email" required placeholder="tu@email.com"
                  class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary placeholder:text-text-body/40 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition" />
              </div>
              <div>
                <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="pais">País de origen</label>
                <input id="pais" type="text" placeholder="Colombia, Venezuela..."
                  class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary placeholder:text-text-body/40 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="servicio">Servicio de interés *</label>
              <select id="servicio" required
                class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition appearance-none">
                <option value="" disabled selected>Selecciona un servicio</option>
                {services.map(s => <option value={s}>{s}</option>)}
              </select>
            </div>

            <div>
              <label class="block text-sm font-heading font-semibold text-primary mb-1.5" for="mensaje">Cuéntanos tu situación</label>
              <textarea id="mensaje" rows="4"
                placeholder="Ej: Llegué hace 2 años, tengo permesso di soggiorno y quiero mejorar mi situación laboral..."
                class="w-full border border-border rounded-btn px-4 py-2.5 text-sm text-primary placeholder:text-text-body/40 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent bg-white transition resize-none"></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input id="rgpd" type="checkbox" required class="mt-1 w-4 h-4 rounded border-border text-accent focus:ring-accent" />
              <label for="rgpd" class="text-xs text-text-body leading-relaxed">
                He leído y acepto la <a href="/privacidad" class="text-accent hover:underline">política de privacidad</a>. Entiendo que mis datos serán usados para contactarme con información relevante a mi consulta.
              </label>
            </div>

            <button type="submit"
              class="w-full bg-accent hover:bg-[#5248e8] text-white font-heading font-semibold px-6 py-3.5 rounded-btn transition-colors duration-200 text-base">
              Enviar consulta gratuita
            </button>
          </form>
        </div>
        <!-- /GoHighLevel placeholder -->
      </div>

      <!-- Sidebar channels (col-span 2) -->
      <div class="lg:col-span-2 space-y-5">

        <!-- WhatsApp -->
        <a href="https://wa.me/393513427777" target="_blank" rel="noopener noreferrer"
          class="flex gap-4 bg-emerald-50 border border-success/25 rounded-card p-5 hover:border-success/50 transition-colors group">
          <div class="w-10 h-10 bg-success rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-sm group-hover:text-success transition-colors">Escríbenos por WhatsApp</p>
            <p class="text-text-body text-xs mt-0.5">+39 351 342 7777 · Respuesta rápida</p>
          </div>
        </a>

        <!-- Location -->
        <div class="flex gap-4 bg-bg-section border border-border rounded-card p-5">
          <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-sm">Lombardía / Milán</p>
            <p class="text-text-body text-xs mt-0.5">Atención presencial con cita previa</p>
            <p class="text-text-body text-xs">También online para toda Italia</p>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex gap-4 bg-bg-section border border-border rounded-card p-5">
          <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-sm">Horario de atención</p>
            <p class="text-text-body text-xs mt-1">Lunes a Viernes: 9:00 – 18:00</p>
            <p class="text-text-body text-xs">Sábados: 10:00 – 14:00</p>
            <p class="text-text-body/50 text-xs mt-1">Hora italiana (CET/CEST)</p>
          </div>
        </div>

        <!-- Email -->
        <a href="mailto:info@grupointegral.it"
          class="flex gap-4 bg-bg-section border border-border rounded-card p-5 hover:border-accent/40 transition-colors group">
          <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </div>
          <div>
            <p class="font-heading font-semibold text-primary text-sm group-hover:text-accent transition-colors">info@grupointegral.it</p>
            <p class="text-text-body text-xs mt-0.5">Respuesta en menos de 24 horas</p>
          </div>
        </a>

      </div>
    </div>
  </div>
</section>

<!-- WhatsApp floating button (mobile) -->
<a href="https://wa.me/393513427777" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
  class="fixed bottom-6 right-6 z-40 w-14 h-14 bg-success hover:bg-[#097a52] rounded-full shadow-xl flex items-center justify-center transition-all duration-200 hover:scale-110 lg:hidden">
  <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>
