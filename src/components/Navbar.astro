---
const links = [
  { label: 'Servicios',      href: '/#servicios' },
  { label: 'Formación',      href: '/#formacion' },
  { label: 'Sobre nosotros', href: '/sobre-nosotros' },
  { label: 'Aliados',        href: '/aliados' },
  { label: 'Contacto',       href: '/#contacto' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300">
  <div class="container-gi">
    <nav class="flex items-center justify-between h-16 lg:h-18">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center">
          <span class="text-white font-heading font-bold text-sm">GI</span>
        </div>
        <span class="font-heading font-bold text-primary text-lg leading-tight">Grupo<br class="hidden">Integral</span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden lg:flex items-center gap-8">
        {links.map((link) => (
          <li>
            <a href={link.href} class="text-text-body text-sm font-body hover:text-accent transition-colors duration-150">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <a href="https://wa.me/393513427777" target="_blank" rel="noopener noreferrer"
        class="hidden lg:inline-flex items-center gap-2 bg-accent hover:bg-[#5248e8] text-white text-sm font-heading font-semibold px-4 py-2 rounded-btn transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hablar con un asesor
      </a>

      <!-- Mobile hamburger -->
      <button id="menu-btn" aria-label="Abrir menú" aria-expanded="false"
        class="lg:hidden p-2 text-primary hover:text-accent transition-colors">
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white">
    <ul class="container-gi py-4 flex flex-col gap-1">
      {links.map((link) => (
        <li>
          <a href={link.href} class="block py-3 text-text-body font-body hover:text-accent transition-colors duration-150">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-3 border-t border-border mt-2">
        <a href="https://wa.me/393513427777" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 bg-accent text-white text-sm font-heading font-semibold px-4 py-3 rounded-btn w-full justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablar con un asesor
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar    = document.getElementById('navbar')!;
  const menuBtn   = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Sticky shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 8) {
      navbar.classList.add('shadow-nav');
    } else {
      navbar.classList.remove('shadow-nav');
    }
  });

  // Mobile menu toggle
  menuBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on link click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      menuBtn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
