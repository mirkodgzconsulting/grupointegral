---
const services = [
  { label: 'Curso MasterCAF',       href: '/servicios/master-caf' },
  { label: 'Programa GOL (gratis)',  href: '/servicios/programa-gol' },
  { label: 'Test de italiano',       href: '/#servicios' },
  { label: 'Consultoría migratoria', href: '/#servicios' },
  { label: 'Partita IVA',           href: '/#servicios' },
  { label: 'Business Plan',          href: '/#servicios' },
];

const company = [
  { label: 'Quiénes somos', href: '/sobre-nosotros' },
  { label: 'Nuestros aliados', href: '/aliados' },
  { label: 'Ser aliado estratégico', href: '/aliados#contacto' },
  { label: 'Contacto', href: '/#contacto' },
];

const legal = [
  { label: 'Política de privacidad', href: '/privacidad' },
  { label: 'Aviso legal',            href: '/aviso-legal' },
  { label: 'Cookie policy',          href: '/cookies' },
];
---

<footer class="bg-primary text-white">
  <div class="container-gi py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Logo + info -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center shrink-0">
            <span class="text-white font-heading font-bold text-sm">GI</span>
          </div>
          <span class="font-heading font-bold text-white text-lg">Grupo Integral</span>
        </a>
        <p class="text-sm text-white/70 leading-relaxed mb-5">
          Conectamos a la comunidad latina en Italia con los servicios que necesita para crecer.
        </p>
        <ul class="space-y-2 text-sm text-white/70">
          <li class="flex items-center gap-2">
            <span>📍</span> Lombardía / Milán, Italia
          </li>
          <li class="flex items-center gap-2">
            <span>📧</span>
            <a href="mailto:info@grupointegral.it" class="hover:text-white transition-colors">info@grupointegral.it</a>
          </li>
          <li class="flex items-center gap-2">
            <span>📲</span>
            <a href="https://wa.me/393513427777" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">+39 351 342 7777</a>
          </li>
        </ul>
      </div>

      <!-- Col 2: Servicios -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Servicios</h4>
        <ul class="space-y-3">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-sm text-white/70 hover:text-white transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Empresa -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Empresa</h4>
        <ul class="space-y-3">
          {company.map(c => (
            <li>
              <a href={c.href} class="text-sm text-white/70 hover:text-white transition-colors">{c.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Legal -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-3">
          {legal.map(l => (
            <li>
              <a href={l.href} class="text-sm text-white/70 hover:text-white transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>

        <div class="mt-8">
          <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Síguenos</h4>
          <div class="flex gap-4">
            <a href="#" aria-label="Instagram" class="text-white/60 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="#" aria-label="Facebook" class="text-white/60 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="#" aria-label="LinkedIn" class="text-white/60 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-white/50">
      <p>© 2026 Grupo Integral · grupointegral.it</p>
      <p>Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
